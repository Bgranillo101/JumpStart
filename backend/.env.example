# PostgreSQL connection
DATABASE_URL=jdbc:postgresql://localhost:5432/JumpStart_database
PGUSER=your_postgres_username
PGPASSWORD=your_postgres_password

# Server port (defaults to 8080 if not set)
PORT=8080

# Anthropic API key for Claude analysis
CLAUDE_API_KEY=your_claude_api_key

# JWT signing secret (base64-encoded)
JWT_SECRET=your_jwt_secret_base64

# Frontend URL for CORS (defaults to http://localhost:5173 if not set)
FRONTEND_URL=http://localhost:5173
